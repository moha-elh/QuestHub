rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Player profiles: anyone signed-in can read (leaderboards, lobbies);
    // only the owner can write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms: signed-in users can read and join/update lobbies.
    // TODO(security-pass): tighten to field-level checks (players may only
    // touch their own entry, only the host can change status) before launch.
    match /rooms/{roomId} {
      allow read, create, update: if request.auth != null;
      // Deleting is reserved for the leave-room transaction (last player out)
      // and Cloud Functions (admin SDK bypasses rules).
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.players;
    }
  }
}
