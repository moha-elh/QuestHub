rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Player profiles: anyone signed-in can read (leaderboards, lobbies);
    // only the owner can write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms: signed-in users can read and join/update lobbies.
    match /rooms/{roomId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.players;

      // Proofs subcollection: signed-in users can create;
      // only the submitter can update; anyone signed-in can read.
      match /proofs/{proofId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.submitterId;
        allow update: if request.auth != null
          && request.auth.uid == resource.data.submitterId;
        allow delete: if false;
      }
    }
  }
}
